  "query": "\n        SELECT oi.id, oi.book_id, oi.quantity, oi.unit_price,\n               b.title, b.author, b.cover_emoji\n        FROM order_items oi\n        JOIN books b ON b.id = oi.book_id\n        WHERE oi.order_id = $1\n        ",
